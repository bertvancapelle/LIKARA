{
  "realm": "complidata",
  "enabled": true,
  "displayName": "LIKARA",
  "loginTheme": "likara",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "bruteForceProtected": true,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 28800,
  "offlineSessionIdleTimeout": 2592000,
  "roles": {
    "realm": [
      { "name": "viewer", "description": "Tenant-rol: alleen-lezen op inhoud (ADR-010)" },
      { "name": "medewerker", "description": "Tenant-rol: lezen + aanmaken + wijzigen (ADR-010)" },
      { "name": "beheerder", "description": "Tenant-rol: volledige tenant-administratie incl. verwijderen (ADR-010)" },
      { "name": "auditor", "description": "Tenant-rol: alleen-lezen incl. auditlog (ADR-010)" },
      { "name": "platformbeheerder", "description": "Platform-rol: CRUD op Tenant + Platforminstellingen (ADR-012)" },
      { "name": "platformoperator", "description": "Platform-rol: alleen-lezen platform-metadata (ADR-012)" }
    ]
  },
  "clients": [
    {
      "clientId": "complidata-api",
      "name": "CompliData Backend API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "changeme_dev",
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:3000/api/v1/auth/callback"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "access.token.lifespan": "900",
        "client.session.idle.timeout": "28800",
        "post.logout.redirect.uris": "http://localhost:3000/login"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "audience-complidata-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "complidata-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "complidata-ui",
      "name": "CompliData Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:3000/auth/callback"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/login"
      }
    },
    {
      "clientId": "kilara-user-provisioning",
      "name": "KILARA User Provisioning",
      "enabled": true,
      "publicClient": false,
      "secret": "changeme_dev",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    }
  ],
